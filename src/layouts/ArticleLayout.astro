---
import BaseLayout from './BaseLayout.astro';
import TOC from '../components/TOC.astro';
import References from '../components/References.astro';
import AffiliateDisclosure from '../components/AffiliateDisclosure.astro';

export interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: string;
  tags?: string[];
  category?: string;
  sources?: Array<{ title: string; url: string; author?: string; year?: string }>;
  affiliate?: boolean;
  visualsCount?: number;
  hasVideo?: boolean;
  headings?: Array<{ depth: number; slug: string; text: string }>;
  faq?: Array<{ question: string; answer: string }>;
  internalLinks?: string[];
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  tags = [],
  category,
  sources = [],
  affiliate = false,
  visualsCount = 0,
  hasVideo = false,
  headings = [],
  faq = [],
  internalLinks = [],
} = Astro.props;

const articleSchema = {
  '@type': 'Article',
  headline: title,
  description,
  image: heroImage,
  datePublished: pubDate?.toISOString(),
  dateModified: (updatedDate || pubDate)?.toISOString(),
  author: {
    '@type': 'Organization',
    name: import.meta.env.PUBLIC_SITE_NAME + ' Editorial Team',
    url: import.meta.env.PUBLIC_SITE_URL,
  },
  publisher: {
    '@type': 'NewsMediaOrganization',
    name: import.meta.env.PUBLIC_SITE_NAME,
    url: import.meta.env.PUBLIC_SITE_URL,
  },
};

const faqSchema = faq.length > 0 ? {
  '@type': 'FAQPage',
  mainEntity: faq.map((q) => ({
    '@type': 'Question',
    name: q.question,
    acceptedAnswer: { '@type': 'Answer', text: q.answer },
  })),
} : null;

const schema = faqSchema ? {
  '@context': 'https://schema.org',
  '@graph': [articleSchema, faqSchema],
} : { '@context': 'https://schema.org', ...articleSchema };

const lang = import.meta.env.PUBLIC_SITE_LANG || 'en';
const localeMap: Record<string, string> = { ko: 'ko-KR', ja: 'ja-JP', en: 'en-US' };
const tMap: Record<string, { published: string; updated: string; sources: string; visuals: string; video: string; related: string }> = {
  ko: { published: '발행일', updated: '갱신', sources: '건 1차 자료', visuals: '종 시각 자료', video: '영상 요약' },
  ja: { published: '公開', updated: '更新', sources: '件の出典', visuals: '点のビジュアル', video: '動画要約' },
  en: { published: 'Published', updated: 'Updated', sources: 'sources cited', visuals: 'visuals', video: 'Video summary', related: 'Related Reading' },
};
const t = tMap[lang] || tMap.en;
const locale = localeMap[lang] || 'en-US';
---

<BaseLayout
  title={title}
  description={description}
  image={heroImage}
  type="article"
  publishedTime={pubDate?.toISOString()}
  modifiedTime={(updatedDate || pubDate)?.toISOString()}
  schema={schema}
>
  <article class="container mx-auto px-4 py-12 max-w-4xl">
    <header class="mb-8">
      {category && (
        <a
          href={`/category/${category.toLowerCase()}`}
          class="inline-block px-3 py-1 mb-4 text-xs font-semibold uppercase tracking-wider rounded-full bg-accent text-accent-foreground"
        >
          {category}
        </a>
      )}
      <h1 class="text-4xl md:text-5xl font-bold mb-4 text-balance">{title}</h1>
      <p class="text-xl text-muted-foreground text-pretty">{description}</p>

      <div class="flex flex-wrap items-center gap-4 mt-6 text-sm text-muted-foreground">
        <time datetime={pubDate?.toISOString()}>
          {t.published} {pubDate?.toLocaleDateString(locale)}
        </time>
        {updatedDate && updatedDate.getTime() !== pubDate.getTime() && (
          <time datetime={updatedDate.toISOString()} class="text-accent font-semibold">
            {t.updated} {updatedDate.toLocaleDateString(locale)}
          </time>
        )}
        <span>·</span>
        <span>{sources.length} {t.sources}</span>
        {visualsCount > 0 && (
          <>
            <span>·</span>
            <span>{visualsCount} {t.visuals}</span>
          </>
        )}
        {hasVideo && (
          <>
            <span>·</span>
            <span class="text-accent">📹 {t.video}</span>
          </>
        )}
      </div>
    </header>

    {heroImage && (
      <img
        src={heroImage}
        alt={title}
        class="w-full rounded-lg shadow-lg mb-8 aspect-[16/9] object-cover"
      />
    )}

    {affiliate && <AffiliateDisclosure />}

    <div class="grid grid-cols-1 lg:grid-cols-[1fr_280px] gap-8">
      <div class="prose-article">
        <slot />
        {sources.length > 0 && <References sources={sources} />}
      </div>

      {headings.length > 0 && (
        <aside class="hidden lg:block">
          <div class="sticky top-8">
            <TOC headings={headings} />
          </div>
        </aside>
      )}
    </div>

    {internalLinks.length > 0 && (
      <section class="mt-12 pt-8 border-t border-border">
        <h2 class="text-2xl font-bold mb-4">{t.related}</h2>
        <ul class="space-y-2">
          {internalLinks.map((link) => (
            <li>
              <a href={link} class="text-primary hover:underline font-mono text-sm">
                {link}
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    {tags.length > 0 && (
      <footer class="mt-12 pt-8 border-t border-border">
        <div class="flex flex-wrap gap-2">
          {tags.map((tag) => (
            <a
              href={`/tags/${tag}`}
              class="px-3 py-1 text-sm rounded-full bg-muted text-muted-foreground hover:bg-primary hover:text-primary-foreground transition-colors"
            >
              #{tag}
            </a>
          ))}
        </div>
      </footer>
    )}
  </article>
</BaseLayout>
