---
// Affiliate-ready product display box.
// Usage in mdx:
//   <ProductBox
//     name="Example Product"
//     image="accurate product image path" // optional; omit when no accurate product image is available
//     priceHint="$249"
//     pros={["Clear use case", "Good value for the target reader"]}
//     cons={["Check fit/specs before buying"]}
//     href="https://www.amazon.com/s?k=example+product"
//     region="us"
//   />

import Aff from './Aff.astro';

export interface Props {
  name: string;
  image?: string;
  priceHint?: string;
  pros?: string[];
  cons?: string[];
  href: string;
  region?: 'us' | 'uk' | 'kr' | 'jp' | 'ca' | 'de' | 'fr' | 'it' | 'es' | 'in';
  ctaText?: string;
}

const {
  name,
  image,
  priceHint,
  pros = [],
  cons = [],
  href,
  region = 'us',
  ctaText,
} = Astro.props;

const lang = import.meta.env.PUBLIC_SITE_LANG || 'en';
const defaultCta = lang === 'ko' ? 'Amazon에서 보기' : lang === 'ja' ? 'Amazonで見る' : 'View on Amazon';
const labels = {
  pros: lang === 'ko' ? '장점' : lang === 'ja' ? '長所' : 'Pros',
  cons: lang === 'ko' ? '단점' : lang === 'ja' ? '短所' : 'Cons',
  price: lang === 'ko' ? '가격대' : lang === 'ja' ? '価格帯' : 'Price',
};

// Grid layout depends on image presence — single column when no image to avoid empty 1fr cell
const gridClass = image
  ? 'grid grid-cols-1 md:grid-cols-[180px_1fr] gap-5 md:gap-6'
  : 'grid grid-cols-1 gap-5 md:gap-6';

function productSlug(value: string): string {
  return value
    .toLowerCase()
    .replace(/&/g, ' and ')
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-+|-+$/g, '')
    .slice(0, 56) || 'product';
}

const productSubtag = productSlug(name);
const note = lang === 'ko'
  ? '가격·재고·평점은 변동될 수 있으니 구매 전 상세 페이지에서 다시 확인하세요.'
  : lang === 'ja'
    ? '価格・在庫・評価は変動するため、購入前に詳細ページで再確認してください。'
    : 'Price, availability, and ratings can change; verify details on the retailer page before buying.';

---

<div class="product-box my-8 rounded-xl border border-border bg-card/40 p-5 md:p-6 not-prose">
  <div class={gridClass}>
    {image && (
      <div class="aspect-square overflow-hidden rounded-lg bg-muted/30">
        <img src={image} alt={name} width="180" height="180" loading="lazy" decoding="async" class="w-full h-full object-cover" />
      </div>
    )}
    <div class="flex flex-col">
      <h3 class="text-xl font-bold mb-2 leading-tight">{name}</h3>
      {priceHint && (
        <p class="text-sm text-muted-foreground mb-3">
          <span class="font-mono uppercase tracking-wider text-[10px]">{labels.price}</span> · <span class="font-semibold text-foreground">{priceHint}</span>
        </p>
      )}
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-sm mt-1 mb-4">
        {pros.length > 0 && (
          <div>
            <p class="font-mono uppercase tracking-wider text-[10px] text-emerald-700 dark:text-emerald-400 mb-1">+ {labels.pros}</p>
            <ul class="space-y-1 text-foreground/85">
              {pros.map((p) => <li>· {p}</li>)}
            </ul>
          </div>
        )}
        {cons.length > 0 && (
          <div>
            <p class="font-mono uppercase tracking-wider text-[10px] text-rose-700 dark:text-rose-400 mb-1">− {labels.cons}</p>
            <ul class="space-y-1 text-foreground/85">
              {cons.map((c) => <li>· {c}</li>)}
            </ul>
          </div>
        )}
      </div>
      <div class="mt-auto pt-2">
        <Aff href={href} region={region} subtag={productSubtag} class="inline-flex items-center gap-2 px-6 py-3 rounded-lg font-bold text-base shadow-md hover:shadow-lg transition-all bg-amber-400 text-stone-900 hover:bg-amber-500">
          {ctaText || defaultCta} →
        </Aff>
        <p class="mt-2 text-xs leading-relaxed text-muted-foreground">{note}</p>
      </div>
    </div>
  </div>
</div>
