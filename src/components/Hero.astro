---
export interface Props {
  title: string;
  subtitle: string;
  illustration?: string;
  ctaText?: string;
  ctaHref?: string;
}

const {
  title,
  subtitle,
  illustration = '/images/hero-illustration.png',
  ctaText = 'Browse Articles',
  ctaHref = '#latest',
} = Astro.props;
---

<section class="relative overflow-hidden bg-gradient-to-b from-background to-muted/30">
  <div class="container mx-auto px-4 py-16 md:py-24">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <div class="text-center md:text-left">
        <h1
          class="text-4xl md:text-6xl font-bold mb-6 text-balance"
          style="font-family: var(--font-heading)"
        >
          {title}
        </h1>
        <p class="text-xl text-muted-foreground text-pretty mb-8 max-w-2xl">
          {subtitle}
        </p>
        <a href={ctaHref} class="btn-primary">
          {ctaText}
          <svg class="ml-2 h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M12 5l7 7-7 7" />
          </svg>
        </a>
      </div>
      <div class="flex justify-center">
        <img
          src={illustration}
          alt=""
          class="max-w-md w-full h-auto"
          loading="eager"
        />
      </div>
    </div>
  </div>
</section>
