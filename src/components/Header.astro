---
import ThemeToggle from './ThemeToggle.astro';

const siteName = import.meta.env.PUBLIC_SITE_NAME || 'yookahplus';
const edition = import.meta.env.PUBLIC_SITE_EDITION || '';

const navItems = [
  { label: 'About', href: '/about' },
  { label: 'Editorial', href: '/editorial-process' },
  { label: 'Standards', href: '/editorial-standards' },
];
---

<!-- editorial magazine 헤더: 큰 wordmark + 가는 nav + edition 메타 -->
<header class="sticky top-0 z-50 backdrop-blur-md bg-background/85 border-b border-border">
  <!-- 윗 단: edition meta strip -->
  {edition && (
    <div class="border-b border-border/60">
      <div class="container mx-auto px-6 md:px-10 h-7 flex items-center justify-between text-[10px] uppercase tracking-[0.25em] text-muted-foreground font-mono">
        <span>{edition}</span>
        <span class="hidden sm:inline">A data-grounded publication</span>
      </div>
    </div>
  )}

  <!-- 본 단: 큰 wordmark + nav -->
  <div class="container mx-auto px-6 md:px-10 h-16 md:h-20 flex items-center justify-between gap-6">
    <a href="/" class="group flex items-baseline gap-3">
      <span
        class="text-2xl md:text-3xl font-bold tracking-[-0.02em] leading-none transition-colors group-hover:text-primary"
        style="font-family: var(--font-display);"
      >
        {siteName}
      </span>
      <span class="hidden md:inline-block w-1.5 h-1.5 rounded-full bg-accent"></span>
    </a>

    <div class="flex items-center gap-6 md:gap-10">
      <ul class="hidden md:flex items-center gap-7 lg:gap-9 text-sm uppercase tracking-[0.12em]">
        {navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class="relative text-foreground/70 hover:text-foreground transition-colors py-2"
            >
              {item.label}
              <span class="absolute left-0 bottom-0 w-0 h-px bg-foreground transition-all duration-300 group-hover:w-full"></span>
            </a>
          </li>
        ))}
      </ul>
      <ThemeToggle />
    </div>
  </div>
</header>
