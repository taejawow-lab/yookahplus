---
export interface Props {
  title: string;
  description: string;
  href: string;
  image?: string;
  category?: string;
  pubDate: Date;
  readingTime?: number;
  variant?: 'feature' | 'standard';
  index?: number;
}

const { title, description, href, image, category, pubDate, readingTime, variant = 'standard', index = 0 } = Astro.props;

const dateline = pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }).toUpperCase();
const itemNum = String(index + 1).padStart(2, '0');
---

<article class={`group block ${variant === 'feature' ? '' : ''}`}>
  <a href={href} class="block">
    <!-- 매거진 메타 라벨 — 위쪽 small label rail -->
    <div class="flex items-center gap-3 mb-4 text-[10px] uppercase tracking-[0.2em] font-mono text-muted-foreground">
      <span>№ {itemNum}</span>
      <span class="w-6 h-px bg-border"></span>
      {category && (
        <span class="text-accent font-semibold">{category}</span>
      )}
    </div>

    {image && (
      <div class="aspect-[4/5] overflow-hidden mb-5 relative">
        <!-- accent block (feature only) -->
        {variant === 'feature' && (
          <div class="absolute inset-0 bg-accent/15 -rotate-1 scale-95" aria-hidden="true"></div>
        )}
        <img
          src={image}
          alt={title}
          loading="lazy"
          class="relative w-full h-full object-cover transition-all duration-700 group-hover:scale-[1.03]"
        />
      </div>
    )}

    <!-- title — display serif, oversized -->
    <h3
      class={`${variant === 'feature' ? 'text-3xl md:text-4xl' : 'text-xl md:text-2xl'} font-bold mb-3 leading-[1.1] tracking-[-0.01em] text-balance group-hover:text-primary transition-colors duration-500`}
      style="font-family: var(--font-display);"
    >
      {title}
    </h3>

    <!-- description -->
    <p class="text-foreground/65 leading-relaxed mb-5 line-clamp-3 text-[15px]">
      {description}
    </p>

    <!-- 하단 dateline + read more -->
    <div class="flex items-center justify-between text-[11px] uppercase tracking-[0.18em] font-mono text-muted-foreground pt-4 border-t border-border">
      <time datetime={pubDate.toISOString()}>{dateline}</time>
      <span class="inline-flex items-center gap-2 text-foreground/80 group-hover:gap-3 transition-all">
        Read <span aria-hidden="true">→</span>
      </span>
    </div>
  </a>
</article>
