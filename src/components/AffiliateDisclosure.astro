---
const lang = import.meta.env.PUBLIC_SITE_LANG || 'en';
const text = lang === 'ko'
  ? '이 글에는 Amazon Associates를 포함한 제휴 링크가 포함될 수 있으며, 적격 구매 시 일정 수수료를 받을 수 있습니다. 추천은 협찬·광고비가 아닌 자료 검토와 비교 기준을 우선합니다.'
  : 'This article may contain Amazon Associates and other affiliate links. We may earn from qualifying purchases, but recommendations are based on source review, product fit, and practical comparison criteria—not paid placement.';
---

<aside class="affiliate-disclosure" role="note" aria-label="Affiliate disclosure">
  <strong class="block mb-1">
    {lang === 'ko' ? '⚖️ 제휴 링크 안내' : '⚖️ Affiliate Disclosure'}
  </strong>
  <p>{text}</p>
</aside>
