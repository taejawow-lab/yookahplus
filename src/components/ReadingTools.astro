---
export interface Props {
  title: string;
  description: string;
  url?: string;
  category?: string;
}

const { title, description, url = Astro.url.pathname, category = '육아' } = Astro.props;
---

<div class="reading-progress" aria-hidden="true"><span id="reading-progress-bar"></span></div>

<aside class="article-tools mx-auto mb-8 flex max-w-3xl flex-wrap items-center justify-between gap-3 rounded-[1.35rem] border border-border/70 bg-card/90 p-3 shadow-sm sm:p-4" data-article-tools>
  <div class="min-w-0">
    <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-muted-foreground">읽기 도구</p>
    <p class="mt-1 text-sm text-foreground/70">읽던 글을 저장하고, 체크리스트 완료 상태를 이 기기 안에 보관합니다.</p>
  </div>
  <button
    type="button"
    class="save-article-btn inline-flex min-h-11 items-center gap-2 rounded-full border border-border bg-background px-4 text-sm font-bold text-foreground shadow-sm transition hover:border-primary/50 hover:bg-primary/10 focus-visible:outline-ring"
    data-save-article
    data-title={title}
    data-description={description}
    data-url={url}
    data-category={category}
    aria-pressed="false"
  >
    <span aria-hidden="true">♡</span>
    <span data-save-label>보관함에 저장</span>
  </button>
</aside>

<script is:inline>
  (() => {
    const savedKey = 'ykp:savedArticles';
    const checklistKey = 'ykp:checklistState';
    const progressBar = document.getElementById('reading-progress-bar');

    const readJson = (key, fallback) => {
      try { return JSON.parse(localStorage.getItem(key) || JSON.stringify(fallback)); }
      catch { return fallback; }
    };
    const writeJson = (key, value) => localStorage.setItem(key, JSON.stringify(value));

    const updateProgress = () => {
      if (!progressBar) return;
      const doc = document.documentElement;
      const max = Math.max(1, doc.scrollHeight - window.innerHeight);
      const pct = Math.min(100, Math.max(0, (window.scrollY / max) * 100));
      progressBar.style.width = `${pct}%`;
    };
    updateProgress();
    window.addEventListener('scroll', updateProgress, { passive: true });
    window.addEventListener('resize', updateProgress);

    const button = document.querySelector('[data-save-article]');
    if (button) {
      const item = {
        title: button.dataset.title || document.title,
        description: button.dataset.description || '',
        url: button.dataset.url || location.pathname,
        category: button.dataset.category || '육아',
        savedAt: new Date().toISOString(),
      };
      const label = button.querySelector('[data-save-label]');
      const icon = button.querySelector('span[aria-hidden]');
      const sync = () => {
        const saved = readJson(savedKey, []);
        const active = saved.some((entry) => entry.url === item.url);
        button.setAttribute('aria-pressed', String(active));
        if (label) label.textContent = active ? '저장됨' : '보관함에 저장';
        if (icon) icon.textContent = active ? '♥' : '♡';
      };
      button.addEventListener('click', () => {
        const saved = readJson(savedKey, []);
        const exists = saved.some((entry) => entry.url === item.url);
        const next = exists ? saved.filter((entry) => entry.url !== item.url) : [item, ...saved.filter((entry) => entry.url !== item.url)].slice(0, 60);
        writeJson(savedKey, next);
        sync();
      });
      sync();
    }

    document.querySelectorAll('.prose-article li').forEach((li, index) => {
      const text = li.textContent?.trim() || '';
      if (!/[□☐✓✅]|체크|확인|준비|기록|상담|병원|관찰/.test(text)) return;
      if (text.length < 8 || text.length > 160) return;
      const id = `${location.pathname}#li-${index}`;
      li.classList.add('ykp-check-item');
      const checkbox = document.createElement('input');
      checkbox.type = 'checkbox';
      checkbox.className = 'ykp-check-input';
      checkbox.setAttribute('aria-label', `체크: ${text.slice(0, 40)}`);
      const state = readJson(checklistKey, {});
      checkbox.checked = Boolean(state[id]);
      li.classList.toggle('is-checked', checkbox.checked);
      checkbox.addEventListener('change', () => {
        const next = readJson(checklistKey, {});
        next[id] = checkbox.checked;
        writeJson(checklistKey, next);
        li.classList.toggle('is-checked', checkbox.checked);
      });
      li.prepend(checkbox);
    });
  })();
</script>
