---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ArticleCard from '../components/ArticleCard.astro';

const posts = (await getCollection('posts'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featuredPosts = posts.slice(0, 3);
const recentPosts = posts.slice(3, 12);

const siteName = import.meta.env.PUBLIC_SITE_NAME || 'yookahplus';
const siteDescription = import.meta.env.PUBLIC_SITE_DESCRIPTION || '';
const heroTitle = import.meta.env.PUBLIC_SITE_HERO_TITLE || siteName;
const heroSubtitle = import.meta.env.PUBLIC_SITE_HERO_SUBTITLE || siteDescription;
---

<BaseLayout title="Home" description={siteDescription}>
  <Hero
    title={heroTitle}
    subtitle={heroSubtitle}
  />

  {featuredPosts.length > 0 && (
    <section class="container mx-auto px-6 md:px-10 py-20 md:py-28">
      <!-- editorial section header -->
      <div class="grid grid-cols-12 gap-x-6 md:gap-x-8 mb-12 md:mb-16">
        <div class="col-span-12 md:col-span-4">
          <p class="text-[10px] uppercase tracking-[0.25em] font-mono text-accent mb-3">¶ Section 01</p>
          <h2 class="text-5xl md:text-6xl lg:text-7xl font-bold leading-[0.95] tracking-[-0.02em]" style="font-family: var(--font-display);">
            Featured
          </h2>
        </div>
        <div class="col-span-12 md:col-span-7 md:col-start-6 md:pt-4">
          <p class="text-base md:text-lg text-foreground/70 leading-relaxed max-w-xl">
            Hand-picked stories grounded in primary sources and verified data — what we believe is worth your attention right now.
          </p>
          <a href="/posts" class="inline-block mt-4 text-sm uppercase tracking-[0.15em] font-mono border-b border-foreground pb-1 hover:text-primary hover:border-primary transition-colors">
            View archive →
          </a>
        </div>
      </div>

      <!-- asymmetric magazine grid: 1 large + 2 small -->
      <div class="grid grid-cols-12 gap-x-6 md:gap-x-8 gap-y-12 md:gap-y-16">
        {featuredPosts[0] && (
          <div class="col-span-12 md:col-span-7 md:row-span-2">
            <ArticleCard
              title={featuredPosts[0].data.title}
              description={featuredPosts[0].data.description}
              href={`/posts/${featuredPosts[0].slug}`}
              image={featuredPosts[0].data.heroImage}
              category={featuredPosts[0].data.category}
              pubDate={featuredPosts[0].data.pubDate}
              variant="feature"
              index={0}
            />
          </div>
        )}
        {featuredPosts.slice(1).map((post, i) => (
          <div class="col-span-12 md:col-span-5">
            <ArticleCard
              title={post.data.title}
              description={post.data.description}
              href={`/posts/${post.slug}`}
              image={post.data.heroImage}
              category={post.data.category}
              pubDate={post.data.pubDate}
              variant="standard"
              index={i + 1}
            />
          </div>
        ))}
      </div>
    </section>
  )}

  {recentPosts.length > 0 && (
    <section id="latest" class="border-t border-border py-20 md:py-28">
      <div class="container mx-auto px-6 md:px-10">
        <div class="grid grid-cols-12 gap-x-6 md:gap-x-8 mb-12 md:mb-16 items-baseline">
          <div class="col-span-12 md:col-span-5">
            <p class="text-[10px] uppercase tracking-[0.25em] font-mono text-accent mb-3">¶ Section 02</p>
            <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-[0.95] tracking-[-0.02em]" style="font-family: var(--font-display);">
              Recent
            </h2>
          </div>
          <div class="col-span-12 md:col-span-7 md:text-right text-[10px] uppercase tracking-[0.25em] font-mono text-muted-foreground">
            ↓ {recentPosts.length} stories · Sorted by date
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-14">
          {recentPosts.map((post, i) => (
            <ArticleCard
              title={post.data.title}
              description={post.data.description}
              href={`/posts/${post.slug}`}
              image={post.data.heroImage}
              category={post.data.category}
              pubDate={post.data.pubDate}
              variant="standard"
              index={i + 3}
            />
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>
