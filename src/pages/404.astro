---
import BaseLayout from '../layouts/BaseLayout.astro';

const lang = import.meta.env.PUBLIC_SITE_LANG || 'en';
const hasIllust = import.meta.env.PUBLIC_HAS_NOTFOUND_ILLUSTRATION === 'true';
---

<BaseLayout title="404" description="Page not found">
  <section class="container mx-auto px-6 md:px-10 py-24 md:py-40 relative">
    <div class="grid grid-cols-12 gap-x-6 md:gap-x-8 items-center">
      <div class="col-span-12 md:col-span-7 relative z-10">
        <p class="text-[10px] uppercase tracking-[0.25em] font-mono text-accent mb-6">¶ Error · 404</p>
        <h1
          class="text-[28vw] md:text-[20vw] lg:text-[18vw] font-bold leading-[0.85] tracking-[-0.04em] mb-10"
          style="font-family: var(--font-display);"
        >
          404
        </h1>
        <p class="text-2xl md:text-3xl text-foreground/80 mb-10 max-w-lg leading-tight" style="font-family: var(--font-display);">
          {lang === 'ko' ? '페이지를 찾을 수 없습니다.' : 'This page is missing from our archive.'}
        </p>
        <div class="flex items-center gap-6">
          <a href="/" class="btn-primary inline-flex items-center gap-3 px-7 py-3.5 text-sm uppercase tracking-[0.15em] font-semibold">
            ← {lang === 'ko' ? '홈으로' : 'Back to home'}
          </a>
          <span class="text-[10px] uppercase tracking-[0.25em] font-mono text-muted-foreground">
            Try the archive
          </span>
        </div>
      </div>
      {hasIllust && (
        <div class="col-span-12 md:col-span-5 mt-12 md:mt-0 md:-ml-12 relative">
          <div class="absolute inset-0 bg-accent/15 rotate-2 rounded-sm" aria-hidden="true"></div>
          <img src="/images/illustrations/notfound.png" alt="" class="relative w-full h-auto rounded-sm -rotate-[2deg] shadow-[0_30px_80px_-30px_rgba(0,0,0,0.3)]" loading="eager" />
        </div>
      )}
    </div>
  </section>
</BaseLayout>
