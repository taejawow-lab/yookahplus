---
import BaseLayout from '../layouts/BaseLayout.astro';

const milestones = [
  { month: '0–2개월', label: '먹고 자는 리듬 관찰', hint: '수유·수면·기저귀 패턴을 부담 없이 기록합니다.' },
  { month: '3–5개월', label: '목 가누기와 상호작용', hint: '엎드려 놀기, 시선 맞춤, 소리 반응을 살펴봅니다.' },
  { month: '6–8개월', label: '이유식과 앉기 연습', hint: '새 음식 반응과 앉기 균형을 함께 기록합니다.' },
  { month: '9–12개월', label: '이동과 첫 단어 신호', hint: '기기·잡고 서기·손짓·소리 모방을 관찰합니다.' },
  { month: '13–24개월', label: '걷기와 표현 확장', hint: '놀이, 말, 감정 표현, 안전 이슈를 메모합니다.' },
  { month: '25–36개월', label: '생활 습관과 사회성', hint: '배변·수면·또래 놀이·언어 이해를 가족 기준으로 정리합니다.' },
];
---

<BaseLayout title="성장 기록" description="0–36개월 아이의 주요 관찰 포인트를 기기 안에만 저장하는 육아플러스 성장 기록 도구입니다.">
  <section class="container mx-auto px-6 md:px-10 py-16 md:py-24">
    <div class="grid grid-cols-12 gap-x-6 md:gap-x-8 mb-12 md:mb-16 border-b border-border pb-12">
      <div class="col-span-12 md:col-span-5">
        <p class="text-[10px] uppercase tracking-[0.25em] font-mono text-accent mb-3">¶ Growth Tracker</p>
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold leading-[0.95] tracking-[-0.02em]" style="font-family: var(--font-display);">성장 기록</h1>
        <p class="text-sm uppercase tracking-[0.15em] font-mono text-foreground/60 mt-4">0–36mo · local-only</p>
      </div>
      <div class="col-span-12 md:col-span-6 md:col-start-7 md:pt-4">
        <p class="text-base md:text-lg text-foreground/70 leading-relaxed max-w-xl">
          병원 진료를 대신하지 않는 가족용 관찰 노트입니다. 입력한 내용은 서버로 보내지 않고 현재 브라우저 localStorage에만 저장됩니다.
        </p>
      </div>
    </div>

    <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_360px]">
      <div class="grid gap-4">
        {milestones.map((item, index) => (
          <article class="renewal-panel" data-milestone-card>
            <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
              <div>
                <p class="text-[10px] uppercase tracking-[0.2em] font-mono text-accent">{item.month}</p>
                <h2 class="mt-2 text-2xl font-bold" style="font-family: var(--font-display);">{item.label}</h2>
                <p class="mt-2 text-sm leading-relaxed text-foreground/65">{item.hint}</p>
              </div>
              <label class="inline-flex items-center gap-2 rounded-full border border-border bg-background px-4 py-2 text-sm font-bold">
                <input type="checkbox" class="h-4 w-4 accent-primary" data-growth-check={String(index)} />
                확인
              </label>
            </div>
          </article>
        ))}
      </div>

      <aside class="renewal-panel h-fit lg:sticky lg:top-28">
        <h2 class="text-2xl font-bold" style="font-family: var(--font-display);">오늘 메모</h2>
        <p class="mt-2 text-sm text-foreground/65">수면, 식사, 놀이, 걱정되는 신호를 짧게 남겨 다음 진료나 가족 회의 때 확인하세요.</p>
        <label class="mt-5 block text-xs font-bold uppercase tracking-[0.16em] text-muted-foreground" for="growth-note">관찰 메모</label>
        <textarea id="growth-note" rows="8" class="mt-2 w-full rounded-2xl border border-border bg-background p-4 text-sm leading-relaxed outline-none focus:border-primary" placeholder="예: 낮잠 2회, 새 음식 반응 없음, 밤 기침 관찰"></textarea>
        <div class="mt-4 flex flex-wrap gap-3">
          <button type="button" id="growth-save" class="renewal-chip bg-primary text-primary-foreground hover:bg-primary/90">저장</button>
          <button type="button" id="growth-clear" class="renewal-chip">초기화</button>
        </div>
        <p id="growth-status" class="mt-4 text-sm font-semibold text-accent" aria-live="polite"></p>
      </aside>
    </div>

    <script is:inline>
      (() => {
        const key = 'ykp:growthTracker';
        const note = document.getElementById('growth-note');
        const status = document.getElementById('growth-status');
        const checks = Array.from(document.querySelectorAll('[data-growth-check]'));
        const read = () => {
          try { return JSON.parse(localStorage.getItem(key) || '{}'); }
          catch { return {}; }
        };
        const write = (value) => localStorage.setItem(key, JSON.stringify(value));
        const apply = () => {
          const state = read();
          if (note) note.value = state.note || '';
          checks.forEach((check) => { check.checked = Boolean(state.checks?.[check.dataset.growthCheck]); });
        };
        const save = (message = '저장했습니다.') => {
          const current = read();
          const next = { ...current, note: note?.value || '', checks: {}, updatedAt: new Date().toISOString() };
          checks.forEach((check) => { next.checks[check.dataset.growthCheck] = check.checked; });
          write(next);
          if (status) status.textContent = message;
        };
        checks.forEach((check) => check.addEventListener('change', () => save('체크 상태를 저장했습니다.')));
        document.getElementById('growth-save')?.addEventListener('click', () => save());
        document.getElementById('growth-clear')?.addEventListener('click', () => {
          localStorage.removeItem(key);
          apply();
          if (status) status.textContent = '이 기기의 성장 기록을 초기화했습니다.';
        });
        apply();
      })();
    </script>
  </section>
</BaseLayout>
