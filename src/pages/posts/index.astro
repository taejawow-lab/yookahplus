---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';

const POSTS_PER_PAGE = 9;
const categorySlug = (category: string) => category.toLowerCase().trim().replace(/\s+/g, '-');

const posts = (await getCollection('posts'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const siteName = import.meta.env.PUBLIC_SITE_NAME || '';

// Group by category for navigation
const byCategory = posts.reduce((acc, post) => {
  const cat = post.data.category || 'general';
  if (!acc[cat]) acc[cat] = [];
  acc[cat].push(post);
  return acc;
}, {} as Record<string, typeof posts>);

const categories = Object.keys(byCategory).sort();
const totalPages = Math.max(1, Math.ceil(posts.length / POSTS_PER_PAGE));
const pagePosts = posts.slice(0, POSTS_PER_PAGE);
---

<BaseLayout title="All Posts" description={`Complete archive of all ${posts.length} posts on ${siteName}`}>
  <section class="container mx-auto px-6 md:px-10 py-16 md:py-24">

    <!-- editorial header -->
    <div class="grid grid-cols-12 gap-x-6 md:gap-x-8 mb-12 md:mb-16 border-b border-border pb-12">
      <div class="col-span-12 md:col-span-4">
        <p class="text-[10px] uppercase tracking-[0.25em] font-mono text-accent mb-3">¶ Archive</p>
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold leading-[0.95] tracking-[-0.02em]" style="font-family: var(--font-display);">
          All Posts
        </h1>
        <p class="text-sm uppercase tracking-[0.15em] font-mono text-foreground/60 mt-4">
          {posts.length} articles · Page 1 of {totalPages}
        </p>
      </div>
      <div class="col-span-12 md:col-span-7 md:col-start-6 md:pt-4">
        <p class="text-base md:text-lg text-foreground/70 leading-relaxed max-w-xl">
          Every article on {siteName}, sorted by most recent. Use numbered pages, category browsing, or search to find older guides quickly.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a href="/categories/" class="inline-block text-xs uppercase tracking-[0.15em] font-mono border border-border px-3 py-1.5 hover:border-foreground hover:bg-foreground hover:text-background transition-colors">Browse categories</a>
          <a href="/search/" class="inline-block text-xs uppercase tracking-[0.15em] font-mono border border-border px-3 py-1.5 hover:border-foreground hover:bg-foreground hover:text-background transition-colors">Search articles</a>
        </div>
        {categories.length > 1 && (
          <div id="categories" class="mt-6 flex flex-wrap gap-2">
            {categories.map((cat) => (
              <a
                href={`/category/${categorySlug(cat)}/`}
                class="inline-block text-xs uppercase tracking-[0.15em] font-mono border border-border px-3 py-1.5 hover:border-foreground hover:bg-foreground hover:text-background transition-colors"
              >
                {cat} ({byCategory[cat].length})
              </a>
            ))}
          </div>
        )}
      </div>
    </div>

    <!-- post grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-6 md:gap-x-8 gap-y-12">
      {pagePosts.map((post, i) => (
        <ArticleCard
          title={post.data.title}
          description={post.data.description}
          href={`/posts/${post.slug}`}
          image={post.data.heroImage}
          category={post.data.category}
          pubDate={post.data.pubDate}
          variant="standard"
          index={i}
        />
      ))}
    </div>

    {totalPages > 1 && (
      <nav class="mt-16 pt-10 border-t border-border" aria-label="Post pagination">
        <p class="text-[10px] uppercase tracking-[0.25em] font-mono text-foreground/50 mb-4">Pages</p>
        <ol class="flex flex-wrap gap-2">
          {Array.from({ length: totalPages }, (_, index) => index + 1).map((page) => (
            <li>
              <a
                href={page === 1 ? '/posts/' : `/posts/page/${page}/`}
                aria-current={page === 1 ? 'page' : undefined}
                class:list={[
                  'inline-flex h-10 min-w-10 items-center justify-center border px-3 text-sm font-mono transition-colors',
                  page === 1
                    ? 'border-foreground bg-foreground text-background'
                    : 'border-border hover:border-foreground hover:bg-foreground hover:text-background',
                ]}
              >
                {page}
              </a>
            </li>
          ))}
        </ol>
      </nav>
    )}

  </section>
</BaseLayout>
