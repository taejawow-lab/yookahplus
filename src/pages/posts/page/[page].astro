---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ArticleCard from '../../../components/ArticleCard.astro';

export async function getStaticPaths() {
  const POSTS_PER_PAGE = 9;
  const posts = (await getCollection('posts'))
    .filter((post) => !post.data.draft)
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

  const totalPages = Math.max(1, Math.ceil(posts.length / POSTS_PER_PAGE));
  return Array.from({ length: Math.max(0, totalPages - 1) }, (_, index) => {
    const page = index + 2;
    return {
      params: { page: String(page) },
      props: {
        page,
        totalPages,
        posts: posts.slice((page - 1) * POSTS_PER_PAGE, page * POSTS_PER_PAGE),
        totalPosts: posts.length,
      },
    };
  });
}

const { page, totalPages, posts, totalPosts } = Astro.props;
const siteName = import.meta.env.PUBLIC_SITE_NAME || '';
---

<BaseLayout title={`All Posts — Page ${page}`} description={`Page ${page} of the ${siteName} article archive, with ${totalPosts} published guides.`}>
  <section class="container mx-auto px-6 md:px-10 py-16 md:py-24">
    <div class="grid grid-cols-12 gap-x-6 md:gap-x-8 mb-12 md:mb-16 border-b border-border pb-12">
      <div class="col-span-12 md:col-span-4">
        <p class="text-[10px] uppercase tracking-[0.25em] font-mono text-accent mb-3">¶ Archive</p>
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold leading-[0.95] tracking-[-0.02em]" style="font-family: var(--font-display);">
          All Posts
        </h1>
        <p class="text-sm uppercase tracking-[0.15em] font-mono text-foreground/60 mt-4">
          Page {page} of {totalPages} · {totalPosts} articles
        </p>
      </div>
      <div class="col-span-12 md:col-span-7 md:col-start-6 md:pt-4">
        <p class="text-base md:text-lg text-foreground/70 leading-relaxed max-w-xl">
          Continue browsing the complete {siteName} archive with numbered pagination.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a href="/categories/" class="inline-block text-xs uppercase tracking-[0.15em] font-mono border border-border px-3 py-1.5 hover:border-foreground hover:bg-foreground hover:text-background transition-colors">Browse categories</a>
          <a href="/search/" class="inline-block text-xs uppercase tracking-[0.15em] font-mono border border-border px-3 py-1.5 hover:border-foreground hover:bg-foreground hover:text-background transition-colors">Search articles</a>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-6 md:gap-x-8 gap-y-12">
      {posts.map((post, i) => (
        <ArticleCard
          title={post.data.title}
          description={post.data.description}
          href={`/posts/${post.slug}`}
          image={post.data.heroImage}
          category={post.data.category}
          pubDate={post.data.pubDate}
          variant="standard"
          index={i}
        />
      ))}
    </div>

    <nav class="mt-16 pt-10 border-t border-border" aria-label="Post pagination">
      <p class="text-[10px] uppercase tracking-[0.25em] font-mono text-foreground/50 mb-4">Pages</p>
      <ol class="flex flex-wrap gap-2">
        {Array.from({ length: totalPages }, (_, index) => index + 1).map((pageNumber) => (
          <li>
            <a
              href={pageNumber === 1 ? '/posts/' : `/posts/page/${pageNumber}/`}
              aria-current={pageNumber === page ? 'page' : undefined}
              class:list={[
                'inline-flex h-10 min-w-10 items-center justify-center border px-3 text-sm font-mono transition-colors',
                pageNumber === page
                  ? 'border-foreground bg-foreground text-background'
                  : 'border-border hover:border-foreground hover:bg-foreground hover:text-background',
              ]}
            >
              {pageNumber}
            </a>
          </li>
        ))}
      </ol>
    </nav>
  </section>
</BaseLayout>
