---
import BaseLayout from '../layouts/BaseLayout.astro';

const siteName = import.meta.env.PUBLIC_SITE_NAME || 'yookahplus';
const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://example.com';
const domain = siteUrl.replace(/^https?:\/\//, '').replace(/\/$/, '');
const editorEmail = `editor@${domain}`;
const lang = import.meta.env.PUBLIC_SITE_LANG || 'en';
---

<BaseLayout
  title={lang === 'ko' ? '연락처' : lang === 'ja' ? 'お問い合わせ' : 'Contact'}
  description={lang === 'ko' ? `${siteName} 편집부 연락처` : lang === 'ja' ? `${siteName} 編集部` : `Contact ${siteName} editorial team`}
>
  <article class="container mx-auto px-6 md:px-10 py-16 md:py-24 max-w-3xl">
    <div class="mb-12 md:mb-16">
      <p class="text-[10px] uppercase tracking-[0.25em] font-mono text-accent mb-4">¶ Contact</p>
      <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold leading-[0.95] tracking-[-0.025em] mb-6" style="font-family: var(--font-display);">
        {lang === 'ko' ? '연락처' : lang === 'ja' ? 'お問い合わせ' : 'Contact'}
      </h1>
      <p class="text-lg md:text-xl text-foreground/70 max-w-xl leading-relaxed">
        {lang === 'ko'
          ? `${siteName} 편집부에 직접 문의하실 수 있습니다.`
          : lang === 'ja'
            ? `${siteName} 編集部までお気軽にご連絡ください。`
            : `You can reach the ${siteName} editorial team directly.`
        }
      </p>
    </div>

    <!-- email card -->
    <div class="border-l-4 border-accent pl-6 md:pl-8 py-6 mb-12 bg-muted/30 rounded-r-sm">
      <p class="text-[10px] uppercase tracking-[0.25em] font-mono text-muted-foreground mb-2">
        {lang === 'ko' ? '편집부 이메일' : lang === 'ja' ? '編集部メール' : 'Editorial Email'}
      </p>
      <a href={`mailto:${editorEmail}`} class="text-2xl md:text-3xl font-bold tracking-tight underline underline-offset-4 decoration-2 hover:text-accent transition-colors" style="font-family: var(--font-display);">
        {editorEmail}
      </a>
      <p class="text-sm text-muted-foreground mt-3">
        {lang === 'ko'
          ? '영업일 기준 5일 이내 답변드립니다.'
          : lang === 'ja'
            ? '営業日5日以内に回答いたします。'
            : 'We respond within 5 business days.'
        }
      </p>
    </div>

    <div class="prose-article space-y-8 text-[16px] leading-[1.75]">
      {lang === 'ko' && (
        <>
          <section>
            <h2 class="text-2xl font-bold mb-3" style="font-family: var(--font-display);">문의 종류별 안내</h2>
            <div class="space-y-5 mt-5">
              <div>
                <h3 class="font-semibold mb-1">콘텐츠 오류·정정 요청</h3>
                <p class="text-foreground/80">기사의 사실관계, 출처, 데이터에 오류가 있다고 판단되시면 알려주세요. 해당 글의 URL과 구체적인 부분을 함께 보내주시면 빠른 검토가 가능합니다. 검증 후 정정·삭제하며, 정정 사항은 글 하단 '갱신' 표기로 명시됩니다.</p>
              </div>
              <div>
                <h3 class="font-semibold mb-1">제휴·광고 제안</h3>
                <p class="text-foreground/80">본 매체는 광고비를 받은 추천을 게재하지 않습니다. 다만 콘텐츠 주제에 부합하는 제휴 프로그램·데이터 파트너십·연구 자료 제공 제안은 환영합니다. 회사명·제안 내용·관련 자료를 함께 보내주세요.</p>
              </div>
              <div>
                <h3 class="font-semibold mb-1">기고·전문가 인터뷰</h3>
                <p class="text-foreground/80">해당 분야 전문가의 인터뷰·기고 제안은 약력과 전문 분야, 관심 주제를 함께 보내주시면 검토하겠습니다.</p>
              </div>
              <div>
                <h3 class="font-semibold mb-1">개인정보·법적 통지</h3>
                <p class="text-foreground/80">개인정보 처리, 저작권 침해 신고, 기타 법적 통지는 동일 이메일로 보내주시면 우선 처리됩니다.</p>
              </div>
              <div>
                <h3 class="font-semibold mb-1">일반 피드백</h3>
                <p class="text-foreground/80">콘텐츠 품질·주제 제안·읽기 어려움 등 일반 피드백도 환영합니다. 모든 의견은 다음 콘텐츠 기획에 반영됩니다.</p>
              </div>
            </div>
          </section>

          <section>
            <h2 class="text-2xl font-bold mb-3" style="font-family: var(--font-display);">응답 정책</h2>
            <ul class="list-disc pl-6 space-y-1 mt-3">
              <li>일반 문의: 영업일 기준 5일 이내</li>
              <li>오류 정정 요청: 영업일 기준 2일 이내</li>
              <li>법적 통지: 영업일 기준 3일 이내</li>
              <li>토·일·공휴일은 응답 일정에 포함되지 않습니다.</li>
            </ul>
          </section>

          <section>
            <h2 class="text-2xl font-bold mb-3" style="font-family: var(--font-display);">의료·법률 상담은 받지 않습니다</h2>
            <p>본 매체는 정보 제공 매체이며, 의료·법률·재무 분야의 개인 상담은 제공하지 않습니다. 개별 상황에 대한 판단이 필요한 경우 반드시 자격을 갖춘 전문가와 상담하시기 바랍니다.</p>
          </section>
        </>
      )}

      {lang === 'ja' && (
        <>
          <section>
            <h2 class="text-2xl font-bold mb-3" style="font-family: var(--font-display);">お問い合わせ内容別のご案内</h2>
            <div class="space-y-5 mt-5">
              <div>
                <h3 class="font-semibold mb-1">記事の誤り・訂正のご依頼</h3>
                <p class="text-foreground/80">事実関係、出典、データに誤りがあると思われる場合は、該当記事のURLと具体的な箇所をお知らせください。検証のうえ訂正・削除いたします。</p>
              </div>
              <div>
                <h3 class="font-semibold mb-1">提携・広告のご提案</h3>
                <p class="text-foreground/80">本媒体は有料広告による推奨を掲載しません。ただし、コンテンツに関連するアフィリエイトプログラムやデータパートナーシップは歓迎します。</p>
              </div>
              <div>
                <h3 class="font-semibold mb-1">寄稿・専門家インタビュー</h3>
                <p class="text-foreground/80">分野の専門家の方からの寄稿・インタビューのご提案を承ります。略歴と専門分野をお知らせください。</p>
              </div>
              <div>
                <h3 class="font-semibold mb-1">プライバシー・法的通知</h3>
                <p class="text-foreground/80">個人情報、著作権、その他法的通知は同じメールアドレスへお送りください。優先的に対応いたします。</p>
              </div>
              <div>
                <h3 class="font-semibold mb-1">一般のご意見</h3>
                <p class="text-foreground/80">コンテンツの品質、トピックのご提案、その他のフィードバックも歓迎します。今後の編集に活かさせていただきます。</p>
              </div>
            </div>
          </section>
          <section>
            <h2 class="text-2xl font-bold mb-3" style="font-family: var(--font-display);">回答ポリシー</h2>
            <ul class="list-disc pl-6 space-y-1 mt-3">
              <li>一般問合せ: 営業日5日以内</li>
              <li>訂正依頼: 営業日2日以内</li>
              <li>法的通知: 営業日3日以内</li>
            </ul>
          </section>
          <section>
            <h2 class="text-2xl font-bold mb-3" style="font-family: var(--font-display);">医療・法律の個別相談はお受けできません</h2>
            <p>本媒体は情報提供を目的としており、医療・法律・財務の個別相談は提供しておりません。具体的な判断が必要な場合は、必ず資格を持つ専門家にご相談ください。</p>
          </section>
        </>
      )}

      {lang !== 'ko' && lang !== 'ja' && (
        <>
          <section>
            <h2 class="text-2xl font-bold mb-3" style="font-family: var(--font-display);">By Inquiry Type</h2>
            <div class="space-y-5 mt-5">
              <div>
                <h3 class="font-semibold mb-1">Corrections and Factual Errors</h3>
                <p class="text-foreground/80">If you believe an article contains a factual error, source error, or data mistake, let us know. Include the article URL and the specific passage. We verify, correct or remove if needed, and note the change in an "Updated" stamp at the bottom of the article.</p>
              </div>
              <div>
                <h3 class="font-semibold mb-1">Partnerships and Advertising</h3>
                <p class="text-foreground/80">{siteName} does not run paid recommendations. However, we welcome on-topic affiliate programs, data partnerships, and offers of research or sample data. Include your company, the proposal, and any supporting documents.</p>
              </div>
              <div>
                <h3 class="font-semibold mb-1">Guest Contributions and Expert Interviews</h3>
                <p class="text-foreground/80">If you are a domain expert and would like to contribute or be interviewed, send your bio, areas of expertise, and topic ideas.</p>
              </div>
              <div>
                <h3 class="font-semibold mb-1">Privacy and Legal Notices</h3>
                <p class="text-foreground/80">Privacy requests (data access, deletion under GDPR/CCPA), DMCA copyright notices, and other legal communications can be sent to the same email and will be prioritized.</p>
              </div>
              <div>
                <h3 class="font-semibold mb-1">General Feedback</h3>
                <p class="text-foreground/80">We welcome general feedback on content quality, topic suggestions, or accessibility issues. Every message informs our editorial planning.</p>
              </div>
            </div>
          </section>

          <section>
            <h2 class="text-2xl font-bold mb-3" style="font-family: var(--font-display);">Response Policy</h2>
            <ul class="list-disc pl-6 space-y-1 mt-3">
              <li>General inquiries: within 5 business days</li>
              <li>Correction requests: within 2 business days</li>
              <li>Legal notices: within 3 business days</li>
              <li>Weekends and U.S. federal holidays are not counted in response timelines.</li>
            </ul>
          </section>

          <section>
            <h2 class="text-2xl font-bold mb-3" style="font-family: var(--font-display);">No Individual Medical, Legal, or Financial Advice</h2>
            <p>{siteName} is an informational publication. We do not provide individual medical, legal, or financial advice. For decisions specific to your situation, consult a qualified professional in that field.</p>
          </section>
        </>
      )}
    </div>
  </article>
</BaseLayout>
