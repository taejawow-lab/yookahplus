---
import BaseLayout from '../layouts/BaseLayout.astro';

const siteName = import.meta.env.PUBLIC_SITE_NAME || 'yookahplus';
const siteDescription = import.meta.env.PUBLIC_SITE_DESCRIPTION || '';
const lang = import.meta.env.PUBLIC_SITE_LANG || 'en';
const hasIllust = import.meta.env.PUBLIC_HAS_ABOUT_ILLUSTRATION === 'true';
---

<BaseLayout title="About" description={`About ${siteName}`}>
  <article class="container mx-auto px-6 md:px-10 py-16 md:py-24">
    <!-- editorial header -->
    <div class="grid grid-cols-12 gap-x-6 md:gap-x-8 items-end mb-16 md:mb-20">
      <div class="col-span-12 md:col-span-7">
        <p class="text-[10px] uppercase tracking-[0.25em] font-mono text-accent mb-4">¶ Colophon · About</p>
        <h1 class="text-6xl md:text-7xl lg:text-8xl font-bold leading-[0.92] tracking-[-0.025em] mb-6 text-balance" style="font-family: var(--font-display);">
          About {siteName}
        </h1>
        <p class="text-lg md:text-xl text-foreground/70 max-w-xl leading-relaxed">
          {siteDescription}
        </p>
      </div>
      {hasIllust && (
        <div class="col-span-12 md:col-span-5 mt-10 md:mt-0 md:-ml-8 lg:-ml-16 relative">
          <div class="absolute inset-0 bg-primary/15 -rotate-2 rounded-sm" aria-hidden="true"></div>
          <img src="/images/illustrations/about.png" alt="" class="relative w-full h-auto rounded-sm rotate-[1.5deg] shadow-[0_30px_80px_-30px_rgba(0,0,0,0.25)]" loading="eager" />
        </div>
      )}
    </div>

    <!-- body -->
    <div class="grid grid-cols-12 gap-x-6 md:gap-x-8 prose-article max-w-none">
      <div class="col-span-12 md:col-span-3 mb-8 md:mb-0">
        <p class="text-[10px] uppercase tracking-[0.25em] font-mono text-muted-foreground sticky top-28">
          ¶ Editorial mission
        </p>
      </div>
      <div class="col-span-12 md:col-span-8 md:col-start-5 space-y-6 text-[17px] leading-[1.7]">
        {lang === 'ko' ? (
          <>
            <h2 class="text-3xl md:text-4xl font-bold tracking-[-0.01em]" style="font-family: var(--font-display);">운영 원칙</h2>
            <p>{siteName}는 단일 분야의 1차 자료(정부 통계, 학술 연구, 제조사 데이터, 검증된 매체)를 종합하는 큐레이션 매체입니다. 개별 작가의 경험·의견이 아니라, 인용 가능한 데이터와 출처로 모든 주장을 지지합니다.</p>

            <h2 class="text-3xl md:text-4xl font-bold tracking-[-0.01em] mt-12" style="font-family: var(--font-display);">편집부 가치</h2>
            <ul class="space-y-3 list-none pl-0">
              <li class="border-l-2 border-accent pl-4"><strong>데이터 우선</strong> — 모든 비교는 공식 자료에 기반합니다.</li>
              <li class="border-l-2 border-accent pl-4"><strong>협찬 X</strong> — 광고비를 받은 추천은 없습니다. 어필리에이트 수수료는 푸터에 명시.</li>
              <li class="border-l-2 border-accent pl-4"><strong>투명성</strong> — AI 도구의 보조를 받아 작성하며, 모든 데이터는 1차 자료에서 검증합니다.</li>
              <li class="border-l-2 border-accent pl-4"><strong>검증 가능성</strong> — 모든 출처는 본문 링크로 직접 확인할 수 있습니다.</li>
            </ul>

            <h2 class="text-3xl md:text-4xl font-bold tracking-[-0.01em] mt-12" style="font-family: var(--font-display);">제휴·협업·정정 요청</h2>
            <p>이메일: <a href={`mailto:editor@${siteName.toLowerCase()}.org`} class="underline underline-offset-4 decoration-accent hover:text-primary">editor@{siteName.toLowerCase()}.org</a></p>
          </>
        ) : (
          <>
            <h2 class="text-3xl md:text-4xl font-bold tracking-[-0.01em]" style="font-family: var(--font-display);">Editorial Mission</h2>
            <p>{siteName} is a curation publication that aggregates primary sources (government statistics, peer-reviewed research, manufacturer data, and verified industry sources) within a single subject domain. We do not publish personal opinions or experience-based reviews — every claim is backed by citable data with linked sources.</p>

            <h2 class="text-3xl md:text-4xl font-bold tracking-[-0.01em] mt-12" style="font-family: var(--font-display);">Our Editorial Values</h2>
            <ul class="space-y-3 list-none pl-0">
              <li class="border-l-2 border-accent pl-4"><strong>Data First</strong> — Every comparison is grounded in official sources.</li>
              <li class="border-l-2 border-accent pl-4"><strong>No Sponsored Placements</strong> — We never accept payment for recommendations. Affiliate disclosure in footer.</li>
              <li class="border-l-2 border-accent pl-4"><strong>Transparency</strong> — Content is produced with AI assistance; all data is verified against primary sources.</li>
              <li class="border-l-2 border-accent pl-4"><strong>Verifiability</strong> — Every source is linked inline for direct verification.</li>
            </ul>

            <h2 class="text-3xl md:text-4xl font-bold tracking-[-0.01em] mt-12" style="font-family: var(--font-display);">Contact for Corrections, Tips, or Partnerships</h2>
            <p>Email: <a href={`mailto:editor@${siteName.toLowerCase()}.org`} class="underline underline-offset-4 decoration-accent hover:text-primary">editor@{siteName.toLowerCase()}.org</a></p>
          </>
        )}
      </div>
    </div>
  </article>
</BaseLayout>
