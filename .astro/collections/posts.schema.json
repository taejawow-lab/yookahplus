{
  "$ref": "#/definitions/posts",
  "definitions": {
    "posts": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "maxLength": 100
        },
        "description": {
          "type": "string",
          "maxLength": 200
        },
        "pubDate": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "string",
              "format": "date"
            },
            {
              "type": "integer",
              "format": "unix-time"
            }
          ]
        },
        "updatedDate": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "string",
              "format": "date"
            },
            {
              "type": "integer",
              "format": "unix-time"
            }
          ]
        },
        "heroImage": {
          "type": "string"
        },
        "heroIllustration": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "category": {
          "type": "string"
        },
        "sources": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": {
                "type": "string"
              },
              "url": {
                "type": "string",
                "format": "uri"
              },
              "author": {
                "type": "string"
              },
              "year": {
                "type": "string"
              },
              "publication": {
                "type": "string"
              }
            },
            "required": [
              "title",
              "url"
            ],
            "additionalProperties": false
          },
          "minItems": 8,
          "errorMessage": {
            "minItems": "최소 8건의 1차 자료 인용 필요 (v5.3 #1)"
          }
        },
        "visualsCount": {
          "type": "number",
          "minimum": 5,
          "errorMessage": {
            "minimum": "시각 자료 5종 의무 (v5.3 #9-#13)"
          }
        },
        "hasVideo": {
          "type": "boolean",
          "default": false
        },
        "wordCount": {
          "type": "number",
          "minimum": 1500,
          "errorMessage": {
            "minimum": "최소 1500단어 / 한국어 3000자 (v5.3 #3)"
          }
        },
        "affiliate": {
          "type": "boolean",
          "default": false
        },
        "aiDisclosed": {
          "type": "boolean",
          "default": true
        },
        "schemaType": {
          "type": "string",
          "enum": [
            "Article",
            "Review",
            "HowTo",
            "NewsArticle"
          ],
          "default": "Article"
        },
        "faq": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "question": {
                "type": "string"
              },
              "answer": {
                "type": "string"
              }
            },
            "required": [
              "question",
              "answer"
            ],
            "additionalProperties": false
          }
        },
        "internalLinks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "draft": {
          "type": "boolean",
          "default": false
        },
        "$schema": {
          "type": "string"
        }
      },
      "required": [
        "title",
        "description",
        "pubDate",
        "category",
        "sources",
        "visualsCount",
        "wordCount"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}